{
  "id": "floorplan",
  "label": "Floorplan",
  "description": "Basic floorplan components",
  "components": [
    {
      "id": "wall",
      "label": "Wall",
      "description": "Exterior or interior wall section",
      "defaultWidth": 120,
      "defaultHeight": 14,
      "svgPath": "M 0 0 L 120 0 L 120 14 L 0 14 Z",
      "ports": [
        { "id": "port1", "label": "Left End",  "xFraction": 0.0, "yFraction": 0.5, "normalAngle": 180 },
        { "id": "port2", "label": "Center",    "xFraction": 0.5, "yFraction": 0.0, "normalAngle": 270 },
        { "id": "port3", "label": "Right End", "xFraction": 1.0, "yFraction": 0.5, "normalAngle": 0 }
      ],
      "properties": [
        { "key": "visible", "label": "Visible", "type": "enum", "enumValues": ["true","false"], "defaultValue": "true" },
        { "key": "length",  "label": "Length",  "type": "number", "unit": "inches", "defaultValue": 60 },
        { "key": "width",   "label": "Width",   "type": "number", "unit": "inches", "defaultValue": 3.5 }
      ]
    },
    {
      "id": "window",
      "label": "Window",
      "description": "Window opening in a wall",
      "defaultWidth": 48,
      "defaultHeight": 14,
      "svgPath": "M 0 0 L 48 0 L 48 14 L 0 14 Z M 12 0 L 12 14 M 36 0 L 36 14 M 12 7 L 36 7",
      "ports": [
        { "id": "port1", "label": "Center", "xFraction": 0.5, "yFraction": 0.0, "normalAngle": 270 }
      ],
      "properties": [
        { "key": "width", "label": "Width", "type": "number", "unit": "inches", "defaultValue": 36 }
      ]
    },
    {
      "id": "door",
      "label": "Door",
      "description": "Door with swing arc",
      "defaultWidth": 40,
      "defaultHeight": 40,
      "svgPath": "M 0 0 L 0 36 M 0 0 A 36 36 0 0 1 36 36 M 0 36 L 40 36",
      "ports": [
        { "id": "port1", "label": "Frame Left",  "xFraction": 0.0, "yFraction": 0.9, "normalAngle": 270 },
        { "id": "port2", "label": "Frame Right", "xFraction": 1.0, "yFraction": 0.9, "normalAngle": 270 }
      ],
      "properties": [
        { "key": "orientation", "label": "Orientation", "type": "enum", "enumValues": ["Up","Down","Left","Right"], "defaultValue": "Right" },
        { "key": "width",       "label": "Width",       "type": "number", "unit": "inches", "defaultValue": 32 }
      ]
    }
  ]
}
